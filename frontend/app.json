{
  "expo": {
    "name": "Fixi",
    "slug": "fixi",
    "version": "1.3.3",
    "orientation": "portrait",
    "icon": "./assets/images/splash-icon-v133.png",
    "scheme": "fixi",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "web"
    ],
    "ios": {
      "bundleIdentifier": "com.getfixi.app",
      "buildNumber": "20",
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Für schnelles und sicheres Anmelden",
        "NSUserNotificationUsageDescription": "Wir erinnern dich an dein Schuldenfreiheitsdatum und wichtige Meilensteine.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDevelopmentRegion": "de",
        "CFBundleLocalizations": ["de"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/splash-icon-v133.png",
        "backgroundColor": "#00D4AA"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/splash-icon-v133.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon-v133.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#0A0E1A"
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/splash-icon-v133.png",
          "color": "#00D4AA",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65795ac9-ed3b-4749-b589-4d4d8bd7c91c"
      }
    },
    "owner": "keko7777"
  }
}
