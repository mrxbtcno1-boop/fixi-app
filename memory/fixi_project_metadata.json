        "theme_status": "✅ light + dark"
      },
      {
        "route": "/face-id",
        "fox_state": "coaching",
        "speech_bubble_face": "Deine Daten gehören dir. Ich pass auf. 🦊",
        "speech_bubble_finger": "Niemand außer dir kommt hier rein. 🦊",
        "purpose": "Letztes Vertrauens-Signal vor Paywall",
        "features": [
          "Stagger-Animationen (Fox → Kreis → Headline → Trust-Card → CTAs)",
          "Pulse-Animation auf Biometrie-Kreis (1.0 → 1.08, 900ms loop)",
          "3 Trust-Rows (Datenschutz, Lokal, Keine Cloud)",
          "Mint-Gradient CTA + Text-Link Skip"
