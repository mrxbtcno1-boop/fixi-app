{
  "expo": {
    "name": "Fixi",
    "slug": "fixi",
    "version": "1.2.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fixi",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "web"
    ],
    "ios": {
      "bundleIdentifier": "com.getfixi.app",
      "buildNumber": "16",
      "supportsTablet": false,
      "infoPlist": {
        "NSFaceIDUsageDescription": "Für schnelles und sicheres Anmelden",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleDevelopmentRegion": "de",
        "CFBundleLocalizations": ["de"]
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "app"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0E1A"
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "65795ac9-ed3b-4749-b589-4d4d8bd7c91c"
      }
    },
    "owner": "keko7777"
  }
}
